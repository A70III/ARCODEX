{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "arc",
  "version": "1.0.0",
  "identifier": "com.l2s.arc",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/arc/browser"
  },
  "app": {
    "windows": [
      {
        "title": "Arc",
        "width": 1000,
        "height": 700,
        "decorations": false,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
